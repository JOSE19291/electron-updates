{
  "name": "markdown-editor",
  "version": "1.2.0",
  "description": "Markdown Editor",
  "author": "Jose Mateos de la Cruz",
  "main": "index.js",
  "scripts": {
    "start": "set DEBUG=true electron .",
    "publish:github": "npx electron-builder --win -p always"
